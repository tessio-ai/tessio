{
  "name": "@tessio/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/test-db.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed-cli.ts"
  },
  "dependencies": {
    "@tessio/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "@types/pg": "^8.11.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  },
  "license": "AGPL-3.0-only"
}
