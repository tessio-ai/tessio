# ─── Tessio production environment ───────────────────────────────────────────
# Copy to `.env` next to compose.yaml:  cp .env.production.example .env
# `docker compose` auto-loads `.env`. Never commit your filled-in `.env`.

# Image tag to run (ignored when building locally via `docker compose build`).
TESSIO_VERSION=latest

# ── Database / cache (internal compose hostnames; not published to the host) ──
# Use strong, unique passwords. Generate each with:  openssl rand -hex 24
# Whatever you set for POSTGRES_PASSWORD / REDIS_PASSWORD must match its URL below.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgres://tessio:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/tessio
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379

# ── Secrets (REQUIRED — generate fresh values) ──
# Cookie signing. Generate:  openssl rand -base64 48
SESSION_SECRET=
# 32-byte base64 key that encrypts AI provider keys at rest. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TESSIO_SECRET_KEY=

# ── Edition ──
# community (default) = full core ITSM, unlimited agents, no enterprise features.
# enterprise / cloud enable the commercial ee/ features (requires a licensed build).
TESSIO_EDITION=community

# ── Tess AI (bring your own LLM — optional) ──
# Leave blank to configure a per-org key in-app (Settings → Tess AI) instead.
# AI stays OFF until a key is provided; self-host sends data ONLY to the endpoint
# you choose here (use openai-compatible + a local TESSIO_AI_BASE_URL for zero egress).
#   provider: openai | openai-compatible
#TESSIO_AI_PROVIDER=openai
#TESSIO_AI_API_KEY=
# For openai-compatible providers (Azure OpenAI, Ollama, LM Studio, vLLM, a gateway):
#TESSIO_AI_BASE_URL=
#TESSIO_AI_MODEL=gpt-4o-mini
#TESSIO_AI_EMBEDDING_MODEL=text-embedding-3-small
# Token the worker presents to the script runner's /run endpoint. Generate:
#   openssl rand -hex 32
RUNNER_TOKEN=

# ── First admin (optional; seeds on first `up`, idempotent) ──
# Leave blank to skip seeding (e.g. when restoring an existing database).
TESSIO_ADMIN_EMAIL=
TESSIO_ADMIN_PASSWORD=
TESSIO_ADMIN_NAME=

# ── Public address / TLS ──
# ":80" = plain HTTP (local/trials). For automatic HTTPS, set a domain you
# control that resolves to this host, e.g. TESSIO_SITE_ADDRESS=tessio.example.com
TESSIO_SITE_ADDRESS=:80
TESSIO_HTTP_PORT=80
TESSIO_HTTPS_PORT=443

# ── Email ──
# Base URL of this Tessio instance — used in ticket links inside notification
# emails. Set to your public URL, e.g. https://tessio.example.com
TESSIO_SITE_URL=http://localhost
# Inbound IMAP poll interval in milliseconds (default 60 s).
EMAIL_POLL_INTERVAL_MS=60000
# Maximum size (bytes) of a single inbound email attachment (default 10 MB).
EMAIL_ATTACHMENT_MAX_BYTES=10485760
# Scheduled-workflow tick cadence in milliseconds (default 60 s).
#SCHEDULE_TICK_INTERVAL_MS=60000
# SLA breach-check tick cadence in milliseconds (default 60 s).
#SLA_TICK_INTERVAL_MS=60000
