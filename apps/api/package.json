{
  "name": "@tessio/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.4.0",
    "@tessio/ai": "workspace:*",
    "@tessio/db": "workspace:*",
    "@tessio/entitlements": "workspace:*",
    "@tessio/license": "workspace:*",
    "@tessio/shared": "workspace:*",
    "@types/nodemailer": "^8.0.1",
    "ai": "^6.0.197",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.0",
    "imapflow": "^1.4.0",
    "ioredis": "5.10.1",
    "nodemailer": "^8.0.11",
    "openid-client": "^6.8.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "form-data": "^4.0.6",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@tessio/ee-server": "workspace:*"
  },
  "license": "AGPL-3.0-only"
}
