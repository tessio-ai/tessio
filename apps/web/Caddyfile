{$TESSIO_SITE_ADDRESS::80} {
	encode gzip

	# Security headers on every response (verified against the production SPA build:
	# this CSP boots React + the Monaco editor workers without violations).
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Honored only over HTTPS; harmless on plain-HTTP responses.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	# API requests go to the api service on the internal network.
	handle /api/* {
		reverse_proxy api:3000
	}

	# Everything else is the static SPA.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
