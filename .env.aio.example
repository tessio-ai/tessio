# ─── Tessio all-in-one ───────────────────────────────────────────────────────
# cp .env.aio.example .env  (docker compose -f compose.aio.yaml auto-loads .env)
# Prefer the one-liner? curl -fsSL https://raw.githubusercontent.com/tessio-ai/tessio/main/install.sh | sh
TESSIO_VERSION=latest

# ── Datastores ──
# COMPOSE_PROFILES=bundled runs the Postgres + Redis containers from compose.aio.yaml.
# For a managed Postgres/Redis instead: comment COMPOSE_PROFILES out (the containers
# then stay off) and point DATABASE_URL/REDIS_URL below at your instances (the Postgres
# must have the pgvector extension available).
COMPOSE_PROFILES=bundled
# Use strong, unique passwords (generate each with: openssl rand -hex 24) and set the
# matching URLs so the app connects with them.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgres://tessio:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/tessio
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379

# Secrets (REQUIRED — generate fresh):
#   SESSION_SECRET:    openssl rand -base64 48
#   TESSIO_SECRET_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   RUNNER_TOKEN:      openssl rand -hex 32
SESSION_SECRET=
TESSIO_SECRET_KEY=
RUNNER_TOKEN=

# ── Edition ──
# community (default) = full core ITSM, 5 free admin/agent seats (requesters are
# always free & unlimited), no enterprise features. Paid editions need a
# TESSIO_LICENSE_KEY, which also carries the purchased seat count.
TESSIO_EDITION=community
#TESSIO_LICENSE_KEY=
#TESSIO_LICENSE_SERVER_URL=https://license.tessio.ai/license/check-in

# ── Tess AI (bring your own LLM — optional) ──
# Leave blank to configure a per-org key in-app (Settings → Tess AI). AI stays OFF
# until a key is provided; use openai-compatible + a local TESSIO_AI_BASE_URL for
# zero outbound egress. provider: openai | openai-compatible
#TESSIO_AI_PROVIDER=openai
#TESSIO_AI_API_KEY=
#TESSIO_AI_BASE_URL=
#TESSIO_AI_MODEL=gpt-4o-mini
#TESSIO_AI_EMBEDDING_MODEL=text-embedding-3-small

# First admin (optional; seeds on first start):
TESSIO_ADMIN_EMAIL=
TESSIO_ADMIN_PASSWORD=
TESSIO_ADMIN_NAME=

# Public address (":80" plain HTTP). Put a TLS-terminating proxy in front for HTTPS.
TESSIO_SITE_ADDRESS=:80
TESSIO_HTTP_PORT=80

# Email
# Base URL of this Tessio instance — used in ticket links inside notification
# emails. Set to your public URL, e.g. https://tessio.example.com
TESSIO_SITE_URL=http://localhost
# Inbound IMAP poll interval in milliseconds (default 60 s).
EMAIL_POLL_INTERVAL_MS=60000
# Maximum size (bytes) of a single inbound email attachment (default 10 MB).
EMAIL_ATTACHMENT_MAX_BYTES=10485760
# Scheduled-workflow tick cadence in milliseconds (default 60 s).
#SCHEDULE_TICK_INTERVAL_MS=60000
# SLA breach-check tick cadence in milliseconds (default 60 s).
#SLA_TICK_INTERVAL_MS=60000
