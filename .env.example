DATABASE_URL=postgres://tessio:tessio@localhost:5432/tessio
REDIS_URL=redis://localhost:6379
PORT=3000
RUNNER_PORT=3100
HOST=0.0.0.0

# Tess AI — 32-byte key (base64) used to encrypt provider API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TESSIO_SECRET_KEY=

# Edition: community (default) | enterprise | cloud. Enterprise/cloud load the
# commercial ee/ features (SSO, audit log, …); community ships core only.
#TESSIO_EDITION=community

# Tess AI bring-your-own-LLM (optional — or configure per-org in Settings → Tess AI).
# provider: openai | openai-compatible. Use openai-compatible + a local base URL
# (Ollama/LM Studio/vLLM) to run AI with no outbound egress.
#TESSIO_AI_PROVIDER=openai
#TESSIO_AI_API_KEY=
#TESSIO_AI_BASE_URL=
#TESSIO_AI_MODEL=gpt-4o-mini
#TESSIO_AI_EMBEDDING_MODEL=text-embedding-3-small
