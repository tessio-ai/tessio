{$TESSIO_SITE_ADDRESS::80} {
	encode gzip

	# Security headers on every response (see apps/web/Caddyfile for the rationale —
	# this CSP is verified to boot the SPA + Monaco workers).
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	handle /api/* {
		reverse_proxy localhost:3000
	}
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
